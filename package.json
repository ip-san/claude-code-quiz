{
  "name": "claude-code-quiz",
  "version": "1.0.0",
  "description": "Production-ready Electron quiz app for Claude Code learning",
  "author": "Claude Code Quiz Contributors",
  "license": "MIT",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "tsc && vite build && electron-builder",
    "build:web": "tsc && vite build --config vite.config.web.ts",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.config.web.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "lint": "biome lint src/",
    "knip": "knip",
    "circular": "npx madge --circular --extensions ts,tsx src/",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:arch": "node scripts/check-architecture.mjs",
    "cpd": "jscpd src --min-lines 5 --min-tokens 50 --ignore \"**/data/**\"",
    "type-coverage": "type-coverage --strict --at-least 99",
    "check": "tsc --noEmit && biome check src/ && vitest run && type-coverage --strict --at-least 99 && node scripts/quiz-utils.mjs check",
    "check:all": "tsc --noEmit && biome check src/ && vitest run && type-coverage --strict --at-least 99 && node scripts/quiz-utils.mjs check && node scripts/validate-docs.mjs",
    "docs:validate": "node scripts/validate-docs.mjs",
    "quiz:post-add": "node scripts/quiz-utils.mjs randomize && node scripts/quiz-utils.mjs check && vitest run && node scripts/quiz-utils.mjs stats",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "quiz:randomize": "node scripts/quiz-utils.mjs randomize",
    "quiz:stats": "node scripts/quiz-utils.mjs stats",
    "quiz:coverage": "node scripts/quiz-utils.mjs coverage",
    "quiz:check": "node scripts/quiz-utils.mjs check",
    "quiz:search": "node scripts/quiz-utils.mjs search",
    "quiz:edit": "node scripts/quiz-utils.mjs edit",
    "quiz:merge-proposals": "node scripts/quiz-utils.mjs merge-proposals",
    "docs:fetch": "node scripts/fetch-docs.mjs",
    "docs:split": "node scripts/fetch-docs.mjs --split",
    "docs:assemble": "node scripts/fetch-docs.mjs --assemble",
    "docs:status": "node scripts/fetch-docs.mjs --status",
    "docs:check-updates": "node scripts/fetch-docs.mjs --check-updates",
    "verify:diff": "node scripts/verify-state.mjs diff",
    "verify:diff:full": "node scripts/verify-state.mjs diff --full",
    "verify:diff:force": "node scripts/verify-state.mjs diff --force",
    "verify:save": "node scripts/verify-state.mjs save",
    "verify:status": "node scripts/verify-state.mjs status",
    "verify:mapping": "node scripts/verify-state.mjs mapping",
    "quiz:lint": "node scripts/quiz-lint.mjs all",
    "quiz:lint:dry": "node scripts/quiz-lint.mjs all --dry-run",
    "quiz:lint:backtick": "node scripts/quiz-lint.mjs backtick",
    "quiz:lint:url": "node scripts/quiz-lint.mjs url",
    "quiz:lint:terminology": "node scripts/quiz-lint.mjs terminology",
    "quiz:lint:distractor": "node scripts/quiz-lint.mjs distractor",
    "quiz:lint:difficulty": "node scripts/quiz-lint.mjs difficulty",
    "quiz:section-coverage": "node scripts/quiz-utils.mjs section-coverage",
    "quiz:overlap": "node scripts/quiz-utils.mjs overlap",
    "quiz:fact-check": "node scripts/quiz-fact-check.mjs",
    "quiz:cross-check": "node scripts/quiz-cross-check.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@google-analytics/admin": "^9.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "google-auth-library": "^10.6.2",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdom": "^27.4.0",
    "knip": "^6.0.5",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "type-coverage": "^2.29.7",
    "typescript": "^5.5.2",
    "vite": "^5.3.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.claude-code-quiz.desktop",
    "productName": "Claude Code Quiz",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*"
    ],
    "icon": "build/icon.png",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome check --write --no-errors-on-unmatched"
  },
  "type": "module"
}