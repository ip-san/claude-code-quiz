{
  "name": "claude-code-quiz-desktop",
  "version": "1.0.0",
  "description": "Production-ready Electron quiz app for Claude Code learning",
  "author": "Claude Code Quiz Contributors",
  "license": "MIT",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quiz:randomize": "node scripts/quiz-utils.mjs randomize",
    "quiz:stats": "node scripts/quiz-utils.mjs stats",
    "quiz:coverage": "node scripts/quiz-utils.mjs coverage",
    "quiz:check": "node scripts/quiz-utils.mjs check",
    "docs:fetch": "node scripts/fetch-docs.mjs",
    "docs:split": "node scripts/fetch-docs.mjs --split",
    "docs:assemble": "node scripts/fetch-docs.mjs --assemble",
    "docs:status": "node scripts/fetch-docs.mjs --status",
    "verify:diff": "node scripts/verify-state.mjs diff",
    "verify:diff:full": "node scripts/verify-state.mjs diff --full",
    "verify:save": "node scripts/verify-state.mjs save",
    "verify:status": "node scripts/verify-state.mjs status",
    "verify:mapping": "node scripts/verify-state.mjs mapping",
    "generate-icons": "node scripts/generate-icons.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.53.1",
    "vite": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.claude-code-quiz.desktop",
    "productName": "Claude Code Quiz",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*"
    ],
    "icon": "build/icon.png",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "type": "module"
}
