{
  "$schema": "./events-schema.json",
  "measurementId": "G-XXXXXXXXXX",
  "events": [
    {
      "name": "tutorial_progress",
      "description": "チュートリアル完了/スキップ",
      "params": ["action", "slide_index", "platform"]
    },
    {
      "name": "quiz_start",
      "description": "クイズ開始",
      "params": ["quiz_mode", "question_count", "category", "platform"]
    },
    {
      "name": "quiz_complete",
      "description": "クイズ完了",
      "params": ["quiz_mode", "score", "total", "accuracy", "duration_sec", "platform"]
    },
    {
      "name": "chapter_progress",
      "description": "チャプター進捗（全体像モード）",
      "params": ["chapter_id", "action", "accuracy", "platform"]
    },
    {
      "name": "study_first",
      "description": "読んでから解くモード",
      "params": ["chapter_id", "action", "platform"]
    },
    {
      "name": "bookmark",
      "description": "ブックマーク操作",
      "params": ["action", "platform"]
    },
    {
      "name": "quiz_search",
      "description": "検索利用",
      "params": ["result_count", "platform"]
    },
    {
      "name": "reader_open",
      "description": "解説リーダー利用",
      "params": ["platform"]
    },
    {
      "name": "share_result",
      "description": "結果シェア",
      "params": ["method", "platform"]
    },
    {
      "name": "certificate_download",
      "description": "修了証ダウンロード",
      "params": ["quiz_mode", "platform"]
    },
    {
      "name": "quiz_answer",
      "description": "個別問題の回答",
      "params": ["question_id", "category", "difficulty", "is_correct", "platform"]
    },
    {
      "name": "quiz_quit",
      "description": "クイズ途中離脱",
      "params": ["quiz_mode", "answered_count", "total_questions", "platform"]
    },
    {
      "name": "theme_change",
      "description": "テーマ切替（ダーク/ライト）",
      "params": ["theme", "platform"]
    },
    {
      "name": "session_resume",
      "description": "セッション復帰",
      "params": ["quiz_mode", "questions_remaining", "platform"]
    },
    {
      "name": "set_user_properties",
      "description": "ユーザープロパティ設定（セグメント分析用）",
      "params": ["platform"],
      "userProperties": ["mastery_level", "total_quizzes"]
    },
    {
      "name": "app_error",
      "description": "アプリエラー（未処理例外・レンダリングエラー）",
      "params": ["error_message", "error_source", "platform"]
    }
  ]
}
